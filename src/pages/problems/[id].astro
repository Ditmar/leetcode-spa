---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppProvider from '../../context/AppConfigContext';
import ProblemDetail from '../../component-catalog/ProblemDetail/ProblemDetail';
import { CodeEditor } from '../../component-catalog/CodeEditor/CodeEditor';
import { problemsService } from '../../services/problems/problemsService';
import { userService } from '../../services/user/userService';
import type { Language } from '../../component-catalog/CodeEditor/CodeEditor.types';
import type { AuthUser } from '../../services/auth/authService.types';
import type { AppConfig } from '../../utils/config.types';

const locals = Astro.locals as {
  config: AppConfig | null;
  user: AuthUser | null;
};

const { config, user } = locals;
const { id } = Astro.params;
const cookie = Astro.request.headers.get('cookie') ?? '';
const problemId = Number(id);

const isApiStatusError = (err: unknown, status: number): boolean =>
  typeof err === 'object' &&
  err !== null &&
  'status' in err &&
  typeof (err as { status?: unknown }).status === 'number' &&
  (err as { status: number }).status === status;

const sanitizeMetaDescription = (value: string): string =>
  value
    .replace(/<script[\s\S]*?>[\s\S]*?<\/script>/gi, '')
    .replace(/<style[\s\S]*?>[\s\S]*?<\/style>/gi, '')
    .replace(/<[^>]*>/g, '')
    .replace(/\s+/g, ' ')
    .trim()
    .slice(0, 160);

if (!id || Number.isNaN(problemId)) {
  console.warn('[ProblemDetailPage] Invalid problem id:', id);
  return Astro.redirect('/404');
}

let problem;

try {
  problem = await problemsService.getProblemById(problemId, {
    headers: {
      cookie,
    },
  });

  if (!problem) {
    console.warn('[ProblemDetailPage] Problem not found:', problemId);
    return Astro.redirect('/404');
  }
} catch (err: unknown) {
  if (isApiStatusError(err, 404)) {
    return Astro.redirect('/404');
  }

  console.error('[ProblemDetailPage] Unexpected problem fetch error:', err);
  throw err;
}

const problemDetail = {
  ...problem,
  acceptance:
    'acceptance' in problem && typeof problem.acceptance === 'number'
      ? problem.acceptance
      : 0,
  examples: Array.isArray(problem.examples)
    ? problem.examples.map((example) => {
        if (typeof example === 'string') {
          return {
            input: example,
            output: '',
          };
        }

        return example;
      })
    : [],
};

let defaultLanguage: Language = 'javascript';

if (user) {
  try {
    const preferences = await userService.getPreferences(cookie);
    defaultLanguage = preferences.defaultLanguage;
  } catch (err: unknown) {
    console.warn('[ProblemDetailPage] Failed to load user preferences:', err);
  }
}

let prevId: number | undefined;
let nextId: number | undefined;

try {
  const problemsResponse = await problemsService.getProblems(
    {
      pageSize: 100,
    },
    {
      headers: {
        cookie,
      },
    }
  );

  const sortedProblemIds = problemsResponse.data
    .map((item) => item.id)
    .sort((a, b) => a - b);

  const currentIndex = sortedProblemIds.indexOf(problemDetail.id);

  prevId = currentIndex > 0 ? sortedProblemIds[currentIndex - 1] : undefined;
  nextId =
    currentIndex >= 0 && currentIndex < sortedProblemIds.length - 1
      ? sortedProblemIds[currentIndex + 1]
      : undefined;
} catch (err: unknown) {
  console.warn('[ProblemDetailPage] Failed to load previous/next navigation:', err);
}

const metaDescription = sanitizeMetaDescription(problemDetail.description ?? '');
---

<BaseLayout title={`${problemDetail.id}. ${problemDetail.title} — LeetCode Clone`}>
  <meta name="description" content={metaDescription} />

  <AppProvider config={config} user={user} client:load>
    <main class="problem-page">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <div class="breadcrumb-text">
          Problems &gt; {problemDetail.id}. {problemDetail.title}
        </div>

        <div class="problem-navigation" aria-label="Problem navigation">
          {
            prevId ? (
              <a
                class="nav-arrow"
                href={`/problems/${prevId}`}
                data-astro-prefetch
                aria-label="Previous problem"
              >
                ←
              </a>
            ) : (
              <span class="nav-arrow nav-arrow-disabled" aria-hidden="true">
                ←
              </span>
            )
          }

          {
            nextId ? (
              <a
                class="nav-arrow"
                href={`/problems/${nextId}`}
                data-astro-prefetch
                aria-label="Next problem"
              >
                →
              </a>
            ) : (
              <span class="nav-arrow nav-arrow-disabled" aria-hidden="true">
                →
              </span>
            )
          }
        </div>
      </nav>

      <input class="mobile-tab-input" type="radio" name="problem-tab" id="description-tab" checked />
      <input class="mobile-tab-input" type="radio" name="problem-tab" id="code-tab" />

      <div class="mobile-tabs" aria-label="Problem page tabs">
        <label class="mobile-tab" for="description-tab">Description</label>
        <label class="mobile-tab" for="code-tab">Code</label>
      </div>

      <section class="split-layout">
        <aside class="problem-panel">
          <ProblemDetail problem={problemDetail} client:visible />
        </aside>

        <aside class="editor-panel">
          <CodeEditor problem={problemDetail} defaultLanguage={defaultLanguage} client:load />
        </aside>
      </section>
    </main>
  </AppProvider>
</BaseLayout>

<style>
  .problem-page {
    width: 100%;
    min-height: 100vh;
    background: var(--background);
    color: var(--foreground);
    overflow: hidden;
  }

  .breadcrumb {
    height: 48px;
    padding: 12px 16px;
    font-size: 14px;
    font-weight: 700;
    box-sizing: border-box;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .breadcrumb-text {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .problem-navigation {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-arrow {
    width: 32px;
    height: 32px;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--foreground);
    text-decoration: none;
    display: grid;
    place-items: center;
  }

  .nav-arrow-disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .mobile-tab-input,
  .mobile-tabs {
    display: none;
  }

  .split-layout {
    display: flex;
    width: 100%;
    height: calc(100vh - 48px);
  }

  .problem-panel,
  .editor-panel {
    width: 50%;
    height: 100%;
    min-width: 0;
  }

  .problem-panel {
    overflow: auto;
    border-right: 1px solid var(--border);
  }

  .editor-panel {
    overflow: hidden;
  }

  @media (max-width: 1023px) {
    .problem-page {
      overflow: auto;
    }

    .split-layout {
      flex-direction: column;
      height: auto;
    }

    .problem-panel,
    .editor-panel {
      width: 100%;
      height: 600px;
    }

    .problem-panel {
      border-right: none;
      border-bottom: 1px solid var(--border);
    }
  }

  @media (max-width: 767px) {
    .problem-page {
      overflow: hidden;
    }

    .breadcrumb {
      font-size: 13px;
    }

    .mobile-tabs {
      display: grid;
      grid-template-columns: 1fr 1fr;
      height: 44px;
      border-bottom: 1px solid var(--border);
    }

    .mobile-tab {
      display: grid;
      place-items: center;
      font-weight: 700;
      cursor: pointer;
      color: var(--muted-foreground);
    }

    .split-layout {
      height: calc(100vh - 92px);
      display: block;
    }

    .problem-panel,
    .editor-panel {
      width: 100%;
      height: 100%;
      min-height: 0;
      border: none;
    }

    .problem-panel,
    .editor-panel {
      display: none;
    }

    #description-tab:checked ~ .split-layout .problem-panel {
      display: block;
      overflow: auto;
    }

    #code-tab:checked ~ .split-layout .editor-panel {
      display: block;
      overflow: hidden;
    }

    #description-tab:checked ~ .mobile-tabs label[for='description-tab'],
    #code-tab:checked ~ .mobile-tabs label[for='code-tab'] {
      color: var(--foreground);
      border-bottom: 2px solid var(--primary);
    }
  }
</style>
