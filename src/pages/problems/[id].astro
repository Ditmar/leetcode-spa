---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppProvider from '../../context/AppConfigContext';
import ProblemDetail from '../../component-catalog/ProblemDetail/ProblemDetail';
import { CodeEditor } from '../../component-catalog/CodeEditor/CodeEditor';
import { problemsService } from '../../services/problems/problemsService';
import { userService } from '../../services/user/userService';

const { config, user } = Astro.locals;
const { id } = Astro.params;
const cookie = Astro.request.headers.get('cookie') ?? '';

if (!id || Number.isNaN(Number(id))) {
  return Astro.redirect('/404');
}

let problem;

try {
  problem = await problemsService.getProblemById(Number(id), {
    headers: {
      cookie,
    },
  });
} catch (err: unknown) {
  if (
    typeof err === 'object' &&
    err !== null &&
    'status' in err &&
    (err as { status: number }).status === 404
  ) {
    return Astro.redirect('/404');
  }

  throw err;
}

if (!problem) {
  return Astro.redirect('/404');
}

const problemDetail = {
  ...problem,
  acceptance:
    'acceptance' in problem && typeof problem.acceptance === 'number'
      ? problem.acceptance
      : 0,
  examples: problem.examples.map((example) => {
    if (typeof example === 'string') {
      return {
        input: example,
        output: '',
      };
    }

    return example;
  }),
};

const defaultLanguage = user
  ? (await userService.getPreferences(cookie)).defaultLanguage
  : 'javascript';

const metaDescription = (problemDetail.description ?? '').replace(/<[^>]*>/g, '').slice(0, 160);
---

<BaseLayout title={`${problemDetail.id}. ${problemDetail.title} — LeetCode Clone`}>
  <meta name="description" content={metaDescription} />

  <AppProvider config={config} user={user} client:load>
    <main class="problem-page">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        Problems &gt; {problemDetail.id}. {problemDetail.title}
      </nav>

      <section class="split-layout">
        <aside class="problem-panel">
          <ProblemDetail problem={problemDetail} client:visible />
        </aside>

        <aside class="editor-panel">
          <CodeEditor problem={problemDetail} defaultLanguage={defaultLanguage} client:load />
        </aside>
      </section>
    </main>
  </AppProvider>
</BaseLayout>

<style>
  .problem-page {
    width: 100%;
    min-height: 100vh;
    background: var(--background);
    color: var(--foreground);
    overflow: hidden;
  }

  .breadcrumb {
    height: 48px;
    padding: 12px 16px;
    font-size: 14px;
    font-weight: 700;
    box-sizing: border-box;
    border-bottom: 1px solid var(--border);
  }

  .split-layout {
    display: flex;
    width: 100%;
    height: calc(100vh - 48px);
  }

  .problem-panel,
  .editor-panel {
    width: 50%;
    height: 100%;
    min-width: 0;
  }

  .problem-panel {
    overflow: auto;
    border-right: 1px solid var(--border);
  }

  .editor-panel {
    overflow: hidden;
  }

  @media (max-width: 1023px) {
    .problem-page {
      overflow: auto;
    }

    .split-layout {
      flex-direction: column;
      height: auto;
    }

    .problem-panel,
    .editor-panel {
      width: 100%;
      height: 600px;
    }

    .problem-panel {
      border-right: none;
      border-bottom: 1px solid var(--border);
    }
  }

  @media (max-width: 767px) {
    .breadcrumb {
      font-size: 13px;
    }

    .problem-panel,
    .editor-panel {
      min-height: 520px;
    }
  }
</style>
