{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@config": ["src/utils/config.ts"],
      "@utils/*": ["src/utils/*"],
      "@components/*": ["src/component-catalog/*"]
    }
  }
}
