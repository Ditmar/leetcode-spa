# ─────────────────────────────────────────────────────────────────────────────
# Build-time variables (VITE_ prefix → baked into the JS bundle at `astro build`)
# In Docker: pass as --build-arg, NOT as container -e flags.
# ─────────────────────────────────────────────────────────────────────────────
VITE_BASE_PATH=
VITE_DEFAULT_CACHE_TTL=300000

# ─────────────────────────────────────────────────────────────────────────────
# Runtime / server-side only (not exposed to the browser bundle)
# Used by apiClient.ts during Astro's SSR phase (if output: 'server' is enabled)
# ─────────────────────────────────────────────────────────────────────────────
# API_BASE_URL=http://backend:3000/api
