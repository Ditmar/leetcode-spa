# ═══════════════════════════════════════════════════════════════════════════════
# leetcode-spa — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the values for your local environment.
# Never commit .env — it is listed in .gitignore.
#
# Variables prefixed with PUBLIC_ are safe to expose to the browser.
# All other variables are private and must stay server-side only.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Private — server only ──────────────────────────────────────────────────────

# Base URL of the backend API — used for server-to-server requests only.
API_BASE_URL=

# Fetch timeout for API calls in milliseconds. Default: 10000
API_TIMEOUT_MS=

# Secret key used for server-side JWT session validation.
JWT_SECRET=

# Domain scope for authentication cookies. Default: localhost
COOKIE_DOMAIN=

# Application environment. Allowed values: development | staging | production
APP_ENV=

# Application version — injected at build time by CI/CD. Default: 0.0.0
APP_VERSION=

# ── Public — safe to expose to the browser ─────────────────────────────────────

# Base URL of the backend API visible to the browser.
PUBLIC_API_BASE_URL=

# Feature flag — enables the Contests section. Default: true
PUBLIC_FEATURE_CONTESTS=

# Feature flag — enables the Explore section. Default: true
PUBLIC_FEATURE_EXPLORE=